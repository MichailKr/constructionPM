{
  "name": "construction-pm",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for Construction Project Management System",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:web\" --kill-others --names \"🔙BACK,🔜FRONT\" --prefix-colors \"blue,green\"",
    "prepare": "npm run build:shared",
    "build:shared": "npm run build -w packages/shared",
    "dev:backend": "npm run dev -w apps/backend",
    "dev:web": "npm run dev -w apps/web",
    "build:web": "npm run build -w apps/web",
    "lint": "eslint .",
    "test": "echo \"Test runner will be configured later\" && exit 0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.4.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.4.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.3.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/socket.io": "^3.0.1",
    "cors": "^2.8.6",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  }
}
